{
  "displayName": "happy-feed",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "xPos": 0, "yPos": 0, "width": 3, "height": 4,
        "widget": {
          "title": "Vertex datapoints upserted (selected window)",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"aiplatform.googleapis.com/matching_engine/stream_update/datapoint_count\" resource.type=\"aiplatform.googleapis.com/Index\"",
                "aggregation": {
                  "alignmentPeriod": "60s",
                  "perSeriesAligner": "ALIGN_DELTA",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "sparkChartView": { "sparkChartType": "SPARK_LINE" }
          }
        }
      },
      {
        "xPos": 3, "yPos": 0, "width": 3, "height": 4,
        "widget": {
          "title": "Vertex datapoints upserted / min",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"aiplatform.googleapis.com/matching_engine/stream_update/datapoint_count\" resource.type=\"aiplatform.googleapis.com/Index\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_DELTA",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 6, "yPos": 0, "width": 3, "height": 4,
        "widget": {
          "title": "Embedding cost (window total) — calculated*",
          "scorecard": {
            "timeSeriesQuery": {
              "timeSeriesFilter": {
                "filter": "metric.type=\"workload.googleapis.com/happy_feed_embed_cost_usd\" resource.type=\"generic_node\"",
                "aggregation": {
                  "perSeriesAligner": "ALIGN_DELTA",
                  "crossSeriesReducer": "REDUCE_SUM"
                }
              }
            },
            "sparkChartView": { "sparkChartType": "SPARK_LINE" }
          }
        }
      },
      {
        "xPos": 9, "yPos": 0, "width": 3, "height": 4,
        "widget": {
          "title": "Embedding cost / min — calculated*",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"workload.googleapis.com/happy_feed_embed_cost_usd\" resource.type=\"generic_node\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_DELTA",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 0, "yPos": 4, "width": 12, "height": 2,
        "widget": {
          "title": "About the cost numbers",
          "text": {
            "content": "**Embedding cost is calculated, not billed.** Estimated as `ceil(chars / 4)` tokens × **$0.00015 / 1K tokens** (Vertex Gemini embeddings online tier, gemini-embedding-001).\n\nNot included in this dashboard:\n- **Vertex AI Vector Search deployed index** — flat **~$220/mo** (1× e2-standard-2 replica)\n- **Cloud Run worker** — **~$50/mo** with 1 vCPU + 1 GiB always-on (`--no-cpu-throttling`, `--min-instances=1`)\n- **Cloud Run server** — **<$5/mo** at <10 users\n- **GCS storage** — **<$5/mo** (parquets + cursor)\n\nFor actual billing (24–48h lag), see [Cloud Billing console](https://console.cloud.google.com/billing).",
            "format": "MARKDOWN"
          }
        }
      },
      {
        "xPos": 0, "yPos": 6, "width": 12, "height": 4,
        "widget": {
          "title": "Cursor lag (seconds behind real-time)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/flush_cursor_lag_us\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_DELTA",
                      "crossSeriesReducer": "REDUCE_MEAN"
                    },
                    "pickTimeSeriesFilter": {
                      "rankingMethod": "METHOD_MEAN",
                      "numTimeSeries": 1,
                      "direction": "TOP"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 0, "yPos": 10, "width": 6, "height": 4,
        "widget": {
          "title": "Posts indexed / minute",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"workload.googleapis.com/happy_feed_posts_indexed_total\" resource.type=\"generic_node\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_DELTA",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "STACKED_AREA"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 6, "yPos": 10, "width": 6, "height": 4,
        "widget": {
          "title": "Queue depth (max per minute)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/flush_queue_depth\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_99",
                      "crossSeriesReducer": "REDUCE_MAX"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 0, "yPos": 14, "width": 6, "height": 4,
        "widget": {
          "title": "Flush latency (p50 / p95)",
          "xyChart": {
            "dataSets": [
              {
                "legendTemplate": "p50",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/flush_latency_ms\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_50",
                      "crossSeriesReducer": "REDUCE_MEAN"
                    }
                  }
                },
                "plotType": "LINE"
              },
              {
                "legendTemplate": "p95",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/flush_latency_ms\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MEAN"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 6, "yPos": 14, "width": 6, "height": 4,
        "widget": {
          "title": "Flushes & failures / minute",
          "xyChart": {
            "dataSets": [
              {
                "legendTemplate": "ok",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/flush_count\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "LINE"
              },
              {
                "legendTemplate": "failed",
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"logging.googleapis.com/user/flush_failed_count\" resource.type=\"cloud_run_revision\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 0, "yPos": 18, "width": 6, "height": 4,
        "widget": {
          "title": "Worker container memory utilization",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/container/memory/utilizations\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"jetstream-indexer\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_99"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 6, "yPos": 18, "width": 6, "height": 4,
        "widget": {
          "title": "Worker container CPU utilization",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"run.googleapis.com/container/cpu/utilizations\" resource.type=\"cloud_run_revision\" resource.label.\"service_name\"=\"jetstream-indexer\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_99"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 0, "yPos": 22, "width": 6, "height": 4,
        "widget": {
          "title": "Vertex query QPS",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"aiplatform.googleapis.com/matching_engine/query/request_count\" resource.type=\"aiplatform.googleapis.com/IndexEndpoint\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      },
      {
        "xPos": 6, "yPos": 22, "width": 6, "height": 4,
        "widget": {
          "title": "Vertex query latency p95 (ms)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "metric.type=\"aiplatform.googleapis.com/matching_engine/query/latencies\" resource.type=\"aiplatform.googleapis.com/IndexEndpoint\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_PERCENTILE_95",
                      "crossSeriesReducer": "REDUCE_MEAN"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": { "scale": "LINEAR" }
          }
        }
      }
    ]
  }
}
